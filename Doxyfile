# Doxyfile — OpenSkyhawk API documentation
# Generates HTML styled with doxygen-awesome-css + brand overrides.
# Run locally: doxygen Doxyfile → .doxygen/html/
# CI: doxygen Doxyfile → cp -r .doxygen/html/. docs/api/ → mkdocs gh-deploy

PROJECT_NAME           = OpenSkyhawk
INPUT                  = Firmware/Libraries
FILE_PATTERNS          = *.h
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */library.json */README.md

GENERATE_HTML          = YES
HTML_OUTPUT            = .doxygen/html
HTML_EXTRA_STYLESHEET  = tools/doxygen-awesome.css tools/doxygen-brand.css
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
GENERATE_LATEX         = NO
GENERATE_XML           = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO

# Required: expand preprocessor guards so #ifdef ARDUINO_ARCH_STM32 / _RP2040
# blocks are not hidden from Doxygen — without these, most members vanish.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = ARDUINO_ARCH_STM32 \
                         ARDUINO_ARCH_RP2040

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
