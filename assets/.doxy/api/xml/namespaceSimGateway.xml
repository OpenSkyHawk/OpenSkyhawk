        </inbodydescription>
        <location file="Firmware/Libraries/SimGateway/SimGateway.cpp" line="287" column="6" bodyfile="Firmware/Libraries/SimGateway/SimGateway.cpp" bodystart="287" bodyend="303" declfile="Firmware/Libraries/SimGateway/SimGateway.h" declline="147" declcolumn="6"/>
