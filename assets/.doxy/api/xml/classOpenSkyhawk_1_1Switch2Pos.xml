      <memberdef kind="function" id="classOpenSkyhawk_1_1Switch2Pos_1af59f54b2d018698feab3072fd771f520" prot="public" static="no" const="no" explicit="no" inline="no" virt="virtual">
        <type>void</type>
        <definition>void OpenSkyhawk::Switch2Pos::configure</definition>
        <argsstring>() override</argsstring>
        <name>configure</name>
        <qualifiedname>OpenSkyhawk::Switch2Pos::configure</qualifiedname>
        <reimplements refid="classOpenSkyhawk_1_1InputBase_1abffbb409d2f7a53cb075550e5bd35c0c">configure</reimplements>
        <briefdescription>
<para>Configure the input pin. Called by <ref refid="namespacePanelGroup_1a54bf0702b5027fc15906ca378515ad0b" kindref="member">PanelGroup::setup()</ref> after chip.begin(). </para>
        </briefdescription>
        <detaileddescription>
<para>Configures the pin as an input. Does not enable internal pull-ups; board wiring supplies the input bias. Typical <ref refid="namespaceOpenSkyhawk" kindref="compound">OpenSkyhawk</ref> switch nets use external 10 kΩ pull-ups to +3.3V and switch to GND.</para>
<para><simplesect kind="note"><para>Must not be called from the constructor — MCP23017 register writes require the chip to be initialised first. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="Firmware/Libraries/PanelGroup/Switch2Pos.h" line="86" column="10" bodyfile="Firmware/Libraries/PanelGroup/Switch2Pos.cpp" bodystart="25" bodyend="27"/>
      </memberdef>
