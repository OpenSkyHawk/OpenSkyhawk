      <memberdef kind="function" id="namespacePanelGroup_1ab31c183f1fe58194e9c6e512fd9a0371" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void PanelGroup::loop</definition>
        <argsstring>()</argsstring>
        <name>loop</name>
        <qualifiedname>PanelGroup::loop</qualifiedname>
        <briefdescription>
<para>Service all <ref refid="namespacePanelGroup" kindref="compound">PanelGroup</ref> activity. Call every Arduino <ref refid="namespacePanelGroup_1ab31c183f1fe58194e9c6e512fd9a0371" kindref="member">loop()</ref> iteration. </para>
        </briefdescription>
        <detaileddescription>
<para>Calls STM32Board::update(), drains the CAN RX FIFO and dispatches ControlPacket frames to registered OutputBase objects, polls all InputBase objects, and sends a heartbeat CAN frame every 500 ms. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
