      <memberdef kind="function" id="namespaceCANProtocol_1a4a1066c652bf5a9d6dafb6838f1d900d" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void CANProtocol::filterAcceptId</definition>
        <argsstring>(uint32_t canId)</argsstring>
        <name>filterAcceptId</name>
        <qualifiedname>CANProtocol::filterAcceptId</qualifiedname>
        <param>
          <type>uint32_t</type>
          <declname>canId</declname>
        </param>
        <briefdescription>
<para>Accept a specific CAN ID. Use for <ref refid="namespacePanelGroup" kindref="compound">PanelGroup</ref> nodes. </para>
        </briefdescription>
        <detaileddescription>
<para>Adds one ID to the hardware filter list. Call multiple times for multiple IDs. CTRL_BCAST (0x010), TEST_SEQ (0x011), and SYNC_REQ (0x012) are always included automatically by <ref refid="namespaceCANProtocol_1a88802da4205140719f9714cb416f1b2c" kindref="member">start()</ref> — do not add them manually.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>canId</parametername>
</parameternamelist>
<parameterdescription>
<para>11-bit standard CAN ID to accept. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
