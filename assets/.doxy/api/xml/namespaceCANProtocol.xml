      <memberdef kind="function" id="namespaceCANProtocol_1acc6510e0de85e6bf717989ef8c04cf77" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void CANProtocol::startLoopback</definition>
        <argsstring>()</argsstring>
        <name>startLoopback</name>
        <qualifiedname>CANProtocol::startLoopback</qualifiedname>
        <briefdescription>
<para>Start in silent loopback mode — for bench testing only. </para>
        </briefdescription>
        <detaileddescription>
<para>Identical to <ref refid="namespaceCANProtocol_1a88802da4205140719f9714cb416f1b2c" kindref="member">start()</ref> but uses CAN_MODE_SILENT_LOOPBACK: frames transmitted by this node are received back internally without going on the physical bus.</para>
<para><simplesect kind="note"><para>Never call this in production firmware. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
