      <memberdef kind="function" id="classPinRef_1adadada577c72fb0b3534a3354387ddd2" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type></type>
        <definition>PinRef::PinRef</definition>
