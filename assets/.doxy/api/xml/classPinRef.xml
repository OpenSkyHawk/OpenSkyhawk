        <name>PinRef</name>
        <qualifiedname>PinRef::PinRef</qualifiedname>
        <briefdescription>
<para>No-connect sentinel — represents a position with no physical pin. </para>
        </briefdescription>
        <detaileddescription>
<para>All reads return false / 0. All writes are no-ops. Equivalent to PIN_NC. Provided for use in array initialisers. </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="Firmware/Libraries/PanelGroup/PinRef.h" line="69" column="5" bodyfile="Firmware/Libraries/PanelGroup/PinRef.cpp" bodystart="42" bodyend="44"/>
